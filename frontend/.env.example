# Points the app at your local or deployed ZivaDzidzo backend.
EXPO_PUBLIC_API_URL=http://127.0.0.1:5000

# Supabase project (anon/public key only - never the service role key here).
# The app runs without these set, but the auth gate is skipped and only the
# curriculum-audit tab is meaningfully usable.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
