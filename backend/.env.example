# Required for OpenAI-powered curriculum analysis.
OPENAI_API_KEY=
# Legacy demo-mode fallback model for the original curriculum auditor.
OPENAI_MODEL=gpt-4.1-mini
# Pinned dated snapshots (not floating aliases) for the predict task heads and chat.
# See backend/config.js - this is the only place these strings should be referenced from.
OPENAI_PREDICT_MODEL=gpt-4o-2024-08-06
OPENAI_CHAT_MODEL=gpt-4o-mini
PORT=5000

# Optional: audits still run when Supabase is not configured.
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Backend-only, privileged operations (profile provisioning, report storage writes,
# auto-logged LLM cost entries). NEVER ship this to frontend/, never commit it.
SUPABASE_SERVICE_ROLE_KEY=
