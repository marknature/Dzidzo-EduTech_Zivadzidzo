# Server-side provider selection. OpenAI is the default. Choose exactly one provider
# deliberately; ZivaDzidzo never automatically fails over across providers.
LLM_PROVIDER=openai

# OpenAI (default) — required when LLM_PROVIDER=openai.
OPENAI_API_KEY=
# Pinned dated snapshots (not floating aliases) for prediction task heads and chat.
# See backend/config.js - this is the only place these strings should be referenced from.
OPENAI_PREDICT_MODEL=gpt-4o-2024-11-20
OPENAI_CHAT_MODEL=gpt-4o-mini-2024-07-18

# Gemini — required only when LLM_PROVIDER=gemini. Keep this backend-only and do
# not put it in frontend/.env or an EXPO_PUBLIC_* variable.
GEMINI_API_KEY=
GEMINI_PREDICT_MODEL=gemini-2.5-flash

# Anthropic — required only when LLM_PROVIDER=anthropic. Anthropic API usage needs
# an API account/credits; do not treat a consumer Claude plan as an API credential.
ANTHROPIC_API_KEY=
ANTHROPIC_PREDICT_MODEL=claude-haiku-4-5-20251001

# Tool-enabled chat currently requires LLM_PROVIDER=openai. Gemini and Anthropic
# are available for the schema-validated assessment heads, not as silent chat fallbacks.
CORS_ALLOWED_ORIGINS=http://localhost:8081,http://127.0.0.1:8081
PORT=5000

# Required for authenticated product workflows and tenant-scoped persistence.
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Backend-only, privileged operations (profile provisioning, report storage writes,
# auto-logged LLM cost entries). NEVER ship this to frontend/, never commit it.
SUPABASE_SERVICE_ROLE_KEY=
